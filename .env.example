# Пример локального окружения. Скопируй в .env (корень) и server/.env и при необходимости поправь порты.
#
# --- корневой .env (читается docker compose для проброса портов хоста) ---
# POSTGRES_PORT=5433
# REDIS_PORT=6380
#
# --- server/.env (читается сервером через dotenv) ---
# DATABASE_URL=postgres://tower:tower@localhost:5433/tower
# REDIS_URL=redis://localhost:6380
